{
  "manifest_version": 3,
  "name": "YouLy+",
  "default_locale": "en",
  "version": "4.3.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.music.youtube.com/*",
    "*://*.tidal.com/*",
    "*://*.music.apple.com/*",
    "https://api.deepl.com/*",
    "https://api-free.deepl.com/*",
    "https://translate.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/api/*"
  ],
  "action": {
    "default_popup": "src/popup/ui.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{00a6e1f0-4808-45e7-b66d-3a5aa6527a0e}",
      "strict_min_version": "122.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.music.youtube.com/*"
      ],
      "js": [
        "src/lib/sponsorblock.js",
        "src/lib/polyfill.js",
        "src/lib/md3e-progress.js",
        "src/lib/colorTunes.js",
        "src/localization.js",
        "src/modules/lyrics/settings.js",
        "src/modules/lyrics/lyricsManager.js",
        "src/modules/lyrics/lyricsRenderer.js",
        "src/modules/ytmusic/forceTab.js",
        "src/modules/lyrics/dynamicBkg.js",
        "src/modules/ytmusic/index.js",
        "src/content.js"
      ]
    },
    {
      "matches": [
        "*://*.music.apple.com/*"
      ],
      "js": [
        "src/lib/polyfill.js",
        "src/localization.js",
        "src/modules/lyrics/settings.js",
        "src/modules/lyrics/lyricsManager.js",
        "src/modules/lyrics/lyricsRenderer.js",
        "src/modules/lyrics/dynamicBkg.js",
        "src/modules/applemusic/index.js",
        "src/content.js"
      ]
    },
    {
      "matches": [
        "*://*.tidal.com/*"
      ],
      "js": [
        "src/lib/polyfill.js",
        "src/localization.js",
        "src/modules/lyrics/settings.js",
        "src/modules/lyrics/lyricsManager.js",
        "src/modules/lyrics/lyricsRenderer.js",
        "src/modules/lyrics/dynamicBkg.js",
        "src/modules/tidal/index.js",
        "src/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/modules/lyrics/lyrics.css",
        "src/modules/ytmusic/style.css",
        "src/inject/ytmusic/songTracker.js",
        "src/lib/parser.js",
        "src/modules/applemusic/style.css",
        "src/inject/applemusic/songTracker.js",
        "src/assets/loading.gif"
      ],
      "matches": [
        "*://*.music.youtube.com/*",
        "*://*.music.apple.com/*"
      ]
    },
    {
      "resources": [
        "src/modules/lyrics/lyrics.css",
        "src/modules/tidal/style.css",
        "src/lib/parser.js",
        "src/inject/tidal/songTracker.js",
        "src/assets/loading.gif"
      ],
      "matches": [
        "*://*.tidal.com/*"
      ]
    },
    {
      "resources": [
        "src/modules/lyrics/lyrics.css",
        "src/modules/applemusic/style.css",
        "src/assets/loading.gif"
      ],
      "matches": [
        "*://*.music.apple.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "src/background/lyricsHandler.js",
    "type": "module",
    "scripts": [
      "src/background/lyricsHandler.js"
    ]
  }
}